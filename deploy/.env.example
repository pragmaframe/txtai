# Copy to .env and fill in real values before running docker compose.
# Never commit .env to version control.

# ── Google OAuth2 credentials ─────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized redirect URI: https://<MCP_DOMAIN>/callback
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# ── Public hostname ───────────────────────────────────────────────────────────
# The domain OPNSense nginx terminates TLS on, pointing to this host:8080.
MCP_DOMAIN=pragmadb.yourdomain.com

# ── Email allowlist ───────────────────────────────────────────────────────────
# Restrict logins to a single address:  julien@example.com
# or an entire domain:                  example.com
# Leave empty to allow any Google account.
ALLOWED_EMAIL=

# ── Index archive path ────────────────────────────────────────────────────────
# Path to the index.tar.gz on the host.  Defaults to ./index.tar.gz.
# INDEX_PATH=/data/index.tar.gz
